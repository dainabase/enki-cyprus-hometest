# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# App Configuration
VITE_APP_ENV=development
VITE_APP_NAME="Enki Reality Admin"
VITE_DEFAULT_LANGUAGE=en

# Feature Flags
VITE_ENABLE_TESTS=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PREDICTIONS=true

# API Keys (optional)
VITE_GOOGLE_MAPS_KEY=your_google_maps_key
VITE_SENDGRID_API_KEY=your_sendgrid_key

# Development Tools
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true

# Performance
VITE_PAGINATION_SIZE=25
VITE_CACHE_TIME=300000
VITE_STALE_TIME=60000

# Security
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW=3600

# Instructions:
# 1. Copy this file to .env
# 2. Replace all "your_*" values with actual credentials
# 3. Get Supabase credentials from your project dashboard
# 4. Set VITE_APP_ENV to "production" for production builds
# 5. Disable test features in production (VITE_ENABLE_TESTS=false)