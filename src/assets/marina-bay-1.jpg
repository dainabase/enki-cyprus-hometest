            <div id="div_block-302-15" class="ct-div-block oxy-superbox-primary" ><img  id="image-303-15" alt="singapore-university-of-technology-and-design-sutd-360" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAyAAAAGQAQAAAAB+XjmZAAAAAnRSTlMAAHaTzTgAAAA+SURBVHja7cExAQAAAMKg9U9tDQ+gAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAPg2d0AABi1/DLQAAAABJRU5ErkJggg==" class="ct-image lazyload"   data-src="https://chrisogrady.com/wp-content/uploads/2022/11/singapore-university-of-technology-and-design-sutd-360.jpg" decoding="async" data-srcset="https://chrisogrady.com/wp-content/uploads/2022/11/singapore-university-of-technology-and-design-sutd-360.jpg 800w, https://chrisogrady.com/wp-content/uploads/2022/11/singapore-university-of-technology-and-design-sutd-360-300x150.jpg 300w, https://chrisogrady.com/wp-content/uploads/2022/11/singapore-university-of-technology-and-design-sutd-360-768x384.jpg 768w" data-sizes="auto" data-eio-rwidth="800" data-eio-rheight="400" /><noscript><img  id="image-303-15" alt="singapore-university-of-technology-and-design-sutd-360" src="https://chrisogrady.com/wp-content/uploads/2022/11/singapore-university-of-technology-and-design-sutd-360.jpg" class="ct-image" srcset="https://chrisogrady.com/wp-content/uploads/2022/11/singapore-university-of-technology-and-design-sutd-360.jpg 800w, https://chrisogrady.com/wp-content/uploads/2022/11/singapore-university-of-technology-and-design-sutd-360-300x150.jpg 300w, https://chrisogrady.com/wp-content/uploads/2022/11/singapore-university-of-technology-and-design-sutd-360-768x384.jpg 768w" sizes="(max-width: 800px) 100vw, 800px" data-eio="l" /></noscript></div><div id="div_block-304-15" class="ct-div-block oxy-superbox-secondary" ><a id="link-305-15" class="ct-link" href="https://virtualtour.sutd.edu.sg/" target="_blank"  ><h4 id="headline-306-15" class="ct-headline">Singapore University of Technology and Design<br></h4></a></div>          </div>
